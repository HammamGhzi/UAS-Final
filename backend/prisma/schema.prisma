generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Attribute {
  Benefit
  Cost
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model User {
  id        Int      @id @default(autoincrement())
  email  String   @unique @db.VarChar(50)
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sanggars  Sanggar[] // Sanggar yang dikelola Admin
  reviews   Review[]  // Review yang ditulis oleh User
  // createdScores ProductScore[]

  @@map("users")
}

model Region {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sanggars                Sanggar[]
  recommendationHistories RecommendationHistory[]

  @@map("regions")
}

model Sanggar {
  id          Int      @id @default(autoincrement())
  regionId    Int
  adminId     Int?
  name        String   @db.VarChar(150)
  ownerName   String   @db.VarChar(100)
  address     String   @db.Text
  latitude    Decimal  @db.Decimal(10, 8)
  longitude   Decimal  @db.Decimal(11, 8)
  phone       String?  @db.VarChar(20)
  description String?  @db.Text
  image       String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  region   Region    @relation(fields: [regionId], references: [id], onDelete: Restrict)
  admin       User?     @relation(fields: [adminId], references: [id]) // Relasi ke User (Admin)
  products Product[]

  @@index([regionId])
  @@map("sanggars")
}

model BatikCategory {
  id           Int @id @default(autoincrement())

  categoryName String @unique @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products                Product[]
  recommendationHistories RecommendationHistory[]

  @@map("batik_categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  sanggarId   Int
  categoryId  Int
  productName String   @db.VarChar(150)
  price       Decimal  @db.Decimal(12, 0)
  stock       Int      @default(0)
  description String?  @db.Text
  image       String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sanggar Sanggar       @relation(fields: [sanggarId], references: [id], onDelete: Cascade)
  category BatikCategory @relation(fields: [categoryId], references: [id])
  reviews  Review[]
  // score    ProductScore?
  recommendationResults RecommendationResult[]

  @@index([sanggarId])
  @@index([categoryId])
  @@index([price])

  @@map("products")
}

model Review {
  id           Int      @id @default(autoincrement())
  productId    Int
  userId       Int?
  reviewerName String   @db.VarChar(100)
  quality      Int
  popularity   Int
  design       Int
  comment      String?  @db.Text
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade) // Relasi ke User

  @@index([productId])

  @@map("reviews")
}

model Criteria {
  id           Int       @id @default(autoincrement())
  criteriaName String    @unique @db.VarChar(100)
  attribute    Attribute
  description  String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("criterias")
}

