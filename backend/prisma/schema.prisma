generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Attribute {
  Benefit
  Cost
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model User {
  id        Int      @id @default(autoincrement())
  email  String   @unique @db.VarChar(50)
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sanggars  Sanggar[] // Sanggar yang dikelola Admin
  reviews   Review[]  // Review yang ditulis oleh User

  @@map("users")
}

model Region {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sanggars                Sanggar[]

  @@map("regions")
}

model Sanggar {
  id          Int      @id @default(autoincrement())
  regionId    Int
  adminId     Int?
  name        String   @db.VarChar(150)
  ownerName   String   @db.VarChar(100)
  address     String   @db.Text
  latitude    Decimal  @db.Decimal(10, 8)
  longitude   Decimal  @db.Decimal(11, 8)
  phone       String?  @db.VarChar(20)
  description String?  @db.Text
  image       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  region   Region    @relation(fields: [regionId], references: [id], onDelete: Restrict)
  admin       User?     @relation(fields: [adminId], references: [id]) // Relasi ke User (Admin)
  products Product[]

  @@index([regionId])
  @@map("sanggars")
}

model BatikCategory {
  id           Int @id @default(autoincrement())

  categoryName String @unique @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products                Product[]

  @@map("batik_categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  sanggarId   Int
  categoryId  Int
  productName String   @db.VarChar(150)
  price       Decimal  @db.Decimal(12, 0)
  stock       Int      @default(0)
  description String?  @db.Text
  image       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sanggar Sanggar       @relation(fields: [sanggarId], references: [id], onDelete: Cascade)
  category BatikCategory @relation(fields: [categoryId], references: [id])
  reviews  Review[]

  @@index([sanggarId])
  @@index([categoryId])
  @@index([price])

  @@map("products")
}

model Review {
  id           Int      @id @default(autoincrement())
  productId    Int
  userId       Int?
  reviewerName String   @db.VarChar(100)
  quality      Int
  popularity   Int
  design       Int
  comment      String?  @db.Text
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade) // Relasi ke User

  @@index([productId])

  @@map("reviews")
}

model Criteria {
  id           Int       @id @default(autoincrement())
  criteriaName String    @unique @db.VarChar(100)
  attribute    Attribute
  description  String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("criterias")
}

model WeightHistory {
  id                 Int      @id @default(autoincrement())
  priceWeight        Decimal  @db.Decimal(5, 4)
  distanceWeight     Decimal  @db.Decimal(5, 4)
  qualityWeight       Decimal  @db.Decimal(5, 4)
  popularityWeight   Decimal  @db.Decimal(5, 4)
  designWeight       Decimal  @db.Decimal(5, 4)
  createdAt          DateTime @default(now())

  spkSessions        SpkSession[]

  @@map("weight_histories")
}

// Tabel Sesi Pencarian SPK (Sangat Penting)
model SpkSession {
  sessionId       String   @id @db.VarChar(100)
  userId          Int
  regionId        Int?
  categoryId      Int?
  minPrice        Decimal  @default(0) @db.Decimal(12, 0)
  maxPrice        Decimal  @default(999999999) @db.Decimal(12, 0)
  userLat         Decimal  @db.Decimal(10, 8)
  userLon         Decimal  @db.Decimal(11, 8)
  
  // Kolom baru untuk mengambil bobot dari tabel history
  weightHistoryId Int      
  
  createdAt       DateTime @default(now())

  // Relasi eksplisit ke tabel WeightHistory
  weightHistory   WeightHistory @relation(fields: [weightHistoryId], references: [id])

  @@map("spk_sessions")
}